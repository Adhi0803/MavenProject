pipeline {
    agent any


   parameters
   choice(
	    name: 'BROWSER',
	    choices: ['chrome', 'firefox', 'edge', 'ie'],
	    description: 'Select the browser to run the tests on'
   )
   choices(
	      name: 'ENVIRONMENT',
            choices: ['uat', 'qa', 'prod'],
            description: 'Select the environment to run the tests on'
   )
   }
    tools {
        jdk 'Java_JDK'
        maven 'MAVEN'
    }

    stages {
        stage('Checkout Code') {
            steps {
                git url: 'https://github.com/nextgentestingacademy/ITV-Maven-Batch703.git',
                    branch: 'main'
            }
        }

        stage('Build & Test') {
            steps {
                bat "mvn clean test -Dbrowser=${params.BROWSER} -Denvironment=${params.ENVIRONMENT}"
            }
      
    }
}
